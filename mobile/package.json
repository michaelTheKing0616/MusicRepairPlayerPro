{
  "name": "music-repair-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "export-presets": "npx tsx scripts/export-presets.ts",
    "download-ml-models": "node -e \"require('child_process').execSync(process.platform==='win32'?'powershell -ExecutionPolicy Bypass -File scripts/download-ml-models.ps1':'bash scripts/download-ml-models.sh',{stdio:'inherit',cwd:process.cwd()})\"",
    "setup-ffmpeg-kit-android": "node -e \"require('child_process').execSync(process.platform==='win32'?'powershell -ExecutionPolicy Bypass -File scripts/setup-ffmpeg-kit-android.ps1':'bash scripts/setup-ffmpeg-kit-android.sh',{stdio:'inherit',cwd:process.cwd()})\"",
    "postinstall": "node scripts/patch-rn-legacy-android.js && node scripts/patch-ffmpeg-kit-android.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.3.1",
    "@react-native-community/slider": "^5.2.0",
    "@react-native-voice/voice": "^3.2.4",
    "@react-navigation/bottom-tabs": "^7.8.8",
    "@react-navigation/native": "^7.1.22",
    "@react-navigation/native-stack": "^7.14.12",
    "@react-navigation/stack": "^7.6.8",
    "axios": "^1.13.2",
    "ffmpeg-kit-react-native": "^6.0.2",
    "react": "18.3.1",
    "react-native": "0.76.7",
    "react-native-document-picker": "^9.3.1",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^2.29.1",
    "react-native-get-music-files": "git+https://github.com/cinder92/react-native-get-music-files.git",
    "react-native-image-picker": "^8.2.1",
    "react-native-logs": "^5.6.0",
    "react-native-paper": "^5.14.5",
    "react-native-permissions": "^4.1.5",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.18.0",
    "react-native-share": "^11.0.2",
    "react-native-svg": "^15.15.0",
    "react-native-track-player": "^4.1.2",
    "react-native-tts": "^4.1.0",
    "react-native-vector-icons": "^10.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/runtime": "^7.26.0",
    "@react-native-community/cli": "^14.0.0",
    "@react-native/eslint-config": "^0.76.7",
    "@react-native/metro-config": "^0.76.7",
    "@react-native/typescript-config": "^0.76.7",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-test-renderer": "^18.3.0",
    "babel-jest": "^29.7.0",
    "baseline-browser-mapping": "^2.10.27",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "react-test-renderer": "18.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
